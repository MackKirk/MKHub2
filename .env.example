# =============================================================================
# MK Hub - Vari횄징veis de Ambiente para Desenvolvimento Local
# =============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necess횄징rio
# O arquivo .env n횄짙o deve ser commitado (j횄징 est횄징 no .gitignore)

# =============================================================================
# DATABASE - Banco de Dados
# =============================================================================
# Op횄짠횄짙o 1: SQLite local (padr횄짙o para desenvolvimento isolado)
# DATABASE_URL=sqlite:///./var/dev.db

# Op챌찾o 2: PostgreSQL do Render (URL EXTERNA - para desenvolvimento local)
# Use esta URL quando quiser conectar ao banco do Render de sua m찼quina local.
# Obtenha a connection string no painel do Render (Database > Connection) e coloque abaixo.
# NUNCA commite a URL com senha no reposit처rio. Veja SECRETS.example.md.
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# Op챌찾o 3: PostgreSQL do Render (URL INTERNA - apenas para refer챗ncia)
# Esta URL s횄쨀 funciona dentro da rede do Render (mais r횄징pida e segura)
# Use apenas em produ횄짠횄짙o no Render, n횄짙o funciona localmente
# DATABASE_URL=postgresql+psycopg2://user:pass@internal-hostname:5432/dbname

AUTO_CREATE_DB=true

# =============================================================================
# SERVER - Configura횄짠횄쨉es do Servidor
# =============================================================================
PUBLIC_BASE_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000

# =============================================================================
# JWT - Autentica횄짠횄짙o
# =============================================================================
# Gere um secret seguro para desenvolvimento local
# No Render, isso 횄짤 gerado automaticamente
JWT_SECRET=change-me-in-local-development
JWT_TTL=43200
REFRESH_TTL=1209600

# =============================================================================
# STORAGE - Armazenamento de Arquivos
# =============================================================================
# Op횄짠횄짙o: lob (Azure Blob Storage) ou hybrid (local + blob)
STORAGE_PROVIDER=blob

# Azure Blob Storage (opcional para desenvolvimento local)
# AZURE_BLOB_CONNECTION=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_BLOB_CONTAINER=mkhub-files

# =============================================================================
# SMTP - Email
# =============================================================================
# Configura횄짠횄쨉es de email (opcional para desenvolvimento local)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_TLS=true
# MAIL_FROM=noreply@mackkirk.com

# =============================================================================
# INTEGRATIONS - Integra횄짠횄쨉es Externas
# =============================================================================
# Microsoft Graph (opcional)
# GRAPH_APP_CLIENT_ID=your-client-id
# GRAPH_APP_TENANT_ID=your-tenant-id
# GRAPH_APP_CLIENT_SECRET=your-client-secret

# Dataforma (opcional)
# DATAFORMA_API_KEY=your-api-key
# DATAFORMA_SERVICE_CODE=your-service-code

# BambooHR (opcional)
# BAMBOOHR_SUBDOMAIN=your-subdomain
# BAMBOOHR_API_KEY=your-api-key

# =============================================================================
# FEATURE FLAGS - Flags de Funcionalidades
# =============================================================================
FEATURE_FLAGS={}

# =============================================================================
# RATE LIMIT - Limite de Requisi횄짠횄쨉es
# =============================================================================
# Formato: 
횄쨘mero/unidade (ex: 100/minute, 1000/hour)
RATE_LIMIT=100/minute

# Em produ횄짠횄짙o, defina origens permitidas (CORS). Ex: https://mkhub2.onrender.com
# ALLOWED_ORIGINS=*

# Tamanho m횄징ximo de upload em MB (padr횄짙o 50)
# UPLOAD_MAX_MB=50

# =============================================================================
# TIMEZONE
# =============================================================================
TZ_DEFAULT=America/Vancouver
